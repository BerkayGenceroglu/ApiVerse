@model ApiVerse.Api.Models.EarthquakeModels.ResultEarthquakeModel
@{
    ViewData["Title"] = "Anlık Depremler";
    Layout = "~/Views/ApiVerseLayout/Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="d-flex align-items-center gap-3 mb-2">
            <div>
                <h3 class="fw-bold mb-0" style="font-size:1.85rem; color:#1e293b; letter-spacing:-0.5px;">
                    Türkiye'de Anlık Deprem Verileri
                </h3>

                <span style="font-size:0.95rem; color:#64748b; font-weight:500;">
                    Kandilli Rasathanesi tarafından sağlanan güncel veriler
                </span>
            </div>
        </div>

        <p class="text-muted mb-0 d-flex align-items-center gap-2" style="font-size:0.95rem;">
            <i class="fa-regular fa-clock"></i>
            Son güncelleme:
            <span class="fw-semibold text-dark">
                @(DateTime.TryParse(Model.cache?.updated_at, out var dt)
                                ? dt.ToString("dd.MM.yyyy HH:mm")
                                : Model.cache?.updated_at)
            </span>
        </p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <!-- AI Analiz Butonu -->
        <a href="/Earthquake/EarthquakeByCityPage" class="btn fw-600 px-4 py-2 rounded-pill shadow-sm transition-all"
           style="background: #4f46e5; color: white; border: none;">
            <i class="fa-solid fa-circle-arrow-right me-2"></i>Şehre Göre Arat ve AI Analizi Yap
        </a>

        <!-- Mevcut Toplam Sayı Rozeti -->
        <span class="badge rounded-pill px-4 py-2" style="background:#222e3e; font-size:1rem; height: fit-content;">
            Toplam @Model.total_returned deprem
        </span>
    </div>
</div>

<div class="row g-3">
    @foreach (var eq in Model.events)
    {
        var mag = eq.preferred_data.magnitude;
        string badgeColor = mag >= 4 ? "#dc2626" : mag >= 3 ? "#ea580c" : mag >= 2 ? "#d97706" : "#16a34a";
        string cardBorder = mag >= 4 ? "border-left: 4px solid #dc2626;" : mag >= 3 ? "border-left: 4px solid #ea580c;" : "border-left: 4px solid #e2e8f0;";
        string seviye = mag >= 4 ? "⚠️ Orta/Güçlü" : mag >= 3 ? "🟠 Hafif" : mag >= 2 ? "🟡 Çok Hafif" : "🟢 Hissedilmez";

        <div class="col-12 col-md-6 col-xl-4">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100" style="@cardBorder">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div style="max-width:60%;">
                        <span class="fw-700" style="font-size:1rem; color:#222e3e;">
                            @eq.preferred_data.location.description
                        </span>
                    </div>
                    <div class="d-flex flex-column align-items-end gap-1">
                        <span class="badge rounded-pill px-3 py-2 fw-700" style="background:@badgeColor; font-size:1.1rem;">
                            M = @mag.ToString("0.0")
                        </span>
                        <span class="badge rounded-pill px-2 py-1 fw-600" style="font-size:0.75rem; background:@badgeColor; opacity:0.85;">
                            @seviye
                        </span>
                    </div>
                </div>

                <div class="d-flex flex-column gap-2" style="font-size:0.9rem; color:#64748b;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-location-dot" style="color:#222e3e; width:16px;"></i>
                        <span>@eq.preferred_data.location.city / @eq.preferred_data.location.district</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-arrow-down" style="color:#222e3e; width:16px;"></i>
                        <span>Derinlik: @eq.preferred_data.depth_km km</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-clock" style="color:#222e3e; width:16px;"></i>
                        <p class="text-muted mb-0">
                            @(DateTime.TryParse(eq.preferred_data.timestamp_local, out var eventDt)
                                                    ? eventDt.ToString("dd.MM.yyyy HH:mm")
                                                    : eq.preferred_data.timestamp_local)
                         </p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-rotate" style="color:#222e3e; width:16px;"></i>
                    <span>
                        @((eq.preferred_data.relative_time ?? "")
                            .Replace("hours", "saat")
                            .Replace("hour", "saat")
                            .Replace("minutes", "dakika")
                            .Replace("minute", "dakika")
                            .Replace("seconds", "saniye")
                            .Replace("second", "saniye")
                            .Replace("days", "gün")
                            .Replace("day", "gün")
                            .Replace("ago", "önce"))
                    </span>
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <i class="fa-solid fa-circle-check" style="color:#222e3e; width:16px;"></i>
                        <span>@string.Join(", ", eq.preferred_data.confirmed_by)</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>