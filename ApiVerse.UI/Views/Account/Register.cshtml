@model RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - Yeni Hesap</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        body {
            /* Yeni Arka Plan: Modern, sıcak tonlarda bir kütüphane/çalışma alanı */
            background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1521737852567-6949f3f9f2b5?q=80&w=1920&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center; /* Yatayda ortala */
            font-family: 'Poppins', sans-serif; /* Daha modern bir font (isteğe bağlı) */
            margin: 0;
            padding: 20px; /* Mobilde kenarlardan boşluk */
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.92); /* Biraz daha az şeffaf, daha okunaklı */
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 25px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            width: 100%;
            /* Formu enine genişletmek için max-width değerini artırdık (örneğin 650px) */
            max-width: 650px;
            transition: all 0.3s ease;
        }

        .form-control {
            border-radius: 12px;
            padding: 14px 18px;
            border: 1px solid #e0e0e0;
            background-color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

            .form-control:focus {
                box-shadow: 0 0 0 4px rgba(44, 62, 80, 0.1);
                border-color: #2c3e50;
                background-color: #fff;
            }

        .btn-register {
            background: #2c3e50; /* Koyu, kurumsal renk */
            color: white;
            border: none;
            border-radius: 12px;
            padding: 15px;
            font-weight: 600;
            font-size: 1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

            .btn-register:hover {
                background: #1a252f;
                transform: translateY(-3px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.25);
                color: white;
            }

        .form-label {
            font-weight: 600;
            color: #333;
            margin-left: 8px;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        .login-link {
            text-decoration: none;
            color: #555;
            font-size: 0.95rem;
            transition: color 0.2s;
        }

            .login-link:hover {
                color: #2c3e50;
                font-weight: 500;
            }

        /* Dosya yükleme alanı stili */
        .file-input-wrapper {
            position: relative;
        }

        input[type="file"]::file-selector-button {
            border: none;
            background: #e0e0e0;
            padding: 8px 18px;
            border-radius: 8px;
            cursor: pointer;
            margin-right: 15px;
            transition: background 0.2s;
            font-size: 0.85rem;
        }

            input[type="file"]::file-selector-button:hover {
                background: #d0d0d0;
            }

        /* Başlık alanı stili */
        .card-header-custom {
            text-align: center;
            margin-bottom: 35px;
        }

            .card-header-custom h2 {
                fw-bold;
                color: #2c3e50;
                margin-bottom: 10px;
            }

            .card-header-custom p {
                color: #777;
                font-size: 1rem;
            }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="card glass-card">
        <div class="card-body p-5">
            <div class="card-header-custom">
                <h2>Kayıt Ol</h2>
                <p>Aramıza katılmak için formu eksiksiz doldurun.</p>
            </div>

            <form asp-action="Register" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label">Adınız</label>
                        <input asp-for="Name" class="form-control" placeholder="Örn: Mert" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Surname" class="form-label">Soyadınız</label>
                        <input asp-for="Surname" class="form-control" placeholder="Örn: Demir" />
                        <span asp-validation-for="Surname" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-posta Adresi</label>
                    <input asp-for="Email" class="form-control" placeholder="mert.demir@ornek.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProfileImage" class="form-label">Profil Fotoğrafı (İsteğe Bağlı)</label>
                    <input asp-for="ProfileImage" type="file" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Şifre</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Şifre Tekrar</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-register w-100">Hesabımı Oluştur</button>
            </form>

            <div class="text-center mt-4 pt-2">
                <a asp-action="Login" class="login-link">Zaten bir hesabın var mı? <b>Giriş Yap</b></a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <script>
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            Toast.fire({
                icon: 'success',
                title: '@TempData["Success"]',
                background: 'rgba(255, 255, 255, 0.95)'
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            const ToastError = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 4000,
                timerProgressBar: true
            });

            ToastError.fire({
                icon: 'error',
                title: 'Hata!',
                text: '@TempData["Error"]',
                background: 'rgba(255, 255, 255, 0.95)'
            });
        </script>
    }
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            // 2. Toast Ayarlarını Yapıyoruz
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            // 3. Bildirimi Fırlatıyoruz
            Toast.fire({
                icon: 'success',
                title: '@TempData["Success"]',
                background: 'rgba(255, 255, 255, 0.95)'
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            const ToastError = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 5000,
                timerProgressBar: true
            });

            ToastError.fire({
                icon: 'error',
                title: 'Hata!',
                text: '@TempData["Error"]',
                background: 'rgba(255, 255, 255, 0.95)'
            });
        </script>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>