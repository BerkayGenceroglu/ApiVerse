@model WeatherResponse

@{
    ViewData["Title"] = "ApiVerse Weather Experience";
    Layout = "~/Views/ApiVerseLayout/Layout.cshtml";
}

@functions {
    public string GetRecommendation(string mainWeather)
    {
        return mainWeather?.ToLower() switch
        {
            "clear" => "Gökyüzü ışıldıyor! Dışarı çıkıp enerjini tazelemek için harika bir an.",
            "clouds" => "Bulutlar gökyüzünü süslüyor, tam kahveni alıp kitap okuma havası.",
            "rain" => "Yağmurun melodisine eşlik et. Şemsiyen şık bir aksesuar olsun!",
            "snow" => "Doğa beyaza büründü. Sıcak bir çikolata ve kar manzarası?",
            "thunderstorm" => "Gök gürültüsü doğanın gücünü hatırlatıyor. Güvende ve sıcak kal!",
            _ => "ApiVerse ile günün ritmini yakala. Her hava durumunun bir hikayesi var!"
        };
    }
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --page-bg: #f1f3f6;
        --card-bg: #ffffff;
        --border: #e2e8f0;
        --text-primary: #1e293b;
        --text-muted: #64748b;
    }

    body {
        background: var(--page-bg);
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-primary);
        padding-bottom: 60px; /* ticker için yer */
    }

    /* ── Page Wrapper ── */
    .weather-wrapper {
        max-width: 1160px;
        margin: 0 auto;
        padding: 40px 20px 24px;
        animation: fadeUp .7s ease-out both;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Header ── */
    .page-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -1.5px;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .page-header p {
        color: var(--text-muted);
        font-weight: 500;
    }

    /* ── Grid ── */
    .weather-container {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 24px;
        margin-top: 36px;
    }

    /* ── Arama Paneli ── */
    .search-container {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 32px;
        height: fit-content;
    }

        .search-container h5 {
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

    .custom-input {
        border-radius: 14px !important;
        border: 1.5px solid var(--border) !important;
        padding: 14px 16px !important;
        font-size: 14px;
        width: 100%;
        transition: border-color .2s;
        background: #fff;
        color: var(--text-primary);
    }

        .custom-input:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 0 3px rgba(99,102,241,.1) !important;
            outline: none;
        }

    .custom-btn {
        border-radius: 14px !important;
        padding: 14px !important;
        background: #1e293b !important;
        color: #fff !important;
        border: none !important;
        font-weight: 700 !important;
        width: 100%;
        margin-top: 12px;
        transition: background .2s, transform .15s;
        cursor: pointer;
    }

        .custom-btn:hover {
            background: #0f172a !important;
            transform: translateY(-1px);
        }

    .popular-cities {
        margin-top: 22px;
        padding: 16px;
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 16px;
    }

        .popular-cities small {
            display: block;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .6px;
            text-transform: uppercase;
            color: #94a3b8;
            margin-bottom: 10px;
        }

    .city-badge {
        display: inline-block;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 12px;
        font-weight: 600;
        color: #475569;
        margin: 3px;
        cursor: default;
    }

    /* ── Bilgi Kutusu (Sol Alt) ── */
    .info-box {
        margin-top: 16px;
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 18px;
    }

        .info-box .ib-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .7px;
            text-transform: uppercase;
            color: #94a3b8;
            margin-bottom: 12px;
        }

    .ib-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5f9;
        font-size: 13px;
    }

        .ib-row:last-child {
            border-bottom: none;
        }

        .ib-row span:first-child {
            color: var(--text-muted);
        }

        .ib-row span:last-child {
            font-weight: 700;
            color: var(--text-primary);
        }

    /* ── Hava Durumu Kartı ── */
    .weather-card {
        border-radius: 28px;
        padding: 40px;
        color: #fff;
        min-height: 480px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
        transition: background .5s ease;
    }

    .bg-default {
        background: #334155;
    }

    .bg-sunny {
        background: #f59e0b;
    }

    .bg-cloudy {
        background: #64748b;
    }

    .bg-rainy {
        background: #2563eb;
    }

    .bg-snowy {
        background: #475569;
    }

    .bg-thunder {
        background: #4c1d95;
    }

    .wc-icon-float {
        position: absolute;
        top: 36px;
        right: 36px;
        font-size: 80px;
        opacity: .9;
        animation: float 4s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }
    }

    .live-badge {
        display: inline-block;
        background: rgba(255,255,255,.2);
        border: 1px solid rgba(255,255,255,.3);
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .6px;
        margin-bottom: 10px;
    }

    .wc-city {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -1px;
    }

    .wc-sub {
        font-size: 13px;
        opacity: .7;
        margin-top: 3px;
    }

    .temp-row {
        display: flex;
        align-items: center;
        gap: 20px;
        margin: 18px 0;
    }

    .temp-big {
        font-size: 7rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -4px;
    }

    .temp-meta p {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .temp-meta span {
        font-size: 13px;
        opacity: .75;
    }

    .pill-row {
        background: rgba(255,255,255,.15);
        border: 1px solid rgba(255,255,255,.2);
        border-radius: 18px;
        padding: 18px 24px;
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 12px;
    }

    .pill-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

        .pill-stat .ps-label {
            font-size: 10px;
            letter-spacing: 1px;
            text-transform: uppercase;
            opacity: .7;
        }

        .pill-stat .ps-val {
            font-size: 15px;
            font-weight: 700;
        }

    .pill-sep {
        border-left: 1px solid rgba(255,255,255,.2);
    }

    .ai-block {
        background: rgba(0,0,0,.18);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 16px;
        padding: 18px;
        margin-top: 16px;
    }

        .ai-block .ai-title {
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .4px;
            margin-bottom: 6px;
        }

        .ai-block .ai-body {
            font-size: 13px;
            opacity: .9;
            line-height: 1.6;
        }

        .ai-block .ai-extra {
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid rgba(255,255,255,.15);
            font-size: 12px;
            opacity: .85;
            line-height: 1.6;
        }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        text-align: center;
        opacity: .45;
    }

        .empty-state i {
            font-size: 64px;
            margin-bottom: 16px;
        }

        .empty-state h3 {
            font-size: 1.2rem;
            font-weight: 700;
        }

        .empty-state p {
            font-size: 13px;
            margin-top: 8px;
            line-height: 1.6;
        }

    /* ── Canlı Ticker ── */
    .ticker-outer {
        background: #1e293b;
        border-top: 1px solid rgba(255,255,255,.06);
        height: 52px;
        display: flex;
        align-items: stretch;
        overflow: hidden;
        width: 100%;
        position: fixed;
        bottom: 0;
        left: 0;
        z-index: 999;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .ticker-label {
        background: #6366f1;
        padding: 0 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.4px;
        color: #fff;
        text-transform: uppercase;
    }

        .ticker-label .dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #4ade80;
            box-shadow: 0 0 0 3px rgba(74,222,128,.25);
        }

    .ticker-scroll {
        overflow: hidden;
        flex: 1;
    }

    .ticker-track {
        display: flex;
        align-items: center;
        height: 52px;
        white-space: nowrap;
    }

    .t-item {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 0 28px;
        height: 52px;
        border-right: 1px solid rgba(255,255,255,.07);
        flex-shrink: 0;
    }

    .t-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .td-clear {
        background: #fbbf24;
    }

    .td-cloud {
        background: #94a3b8;
    }

    .td-rain {
        background: #60a5fa;
    }

    .td-snow {
        background: #bfdbfe;
    }

    .td-thunder {
        background: #a78bfa;
    }

    .td-def {
        background: #6366f1;
    }

    .t-city {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255,255,255,.45);
        letter-spacing: .8px;
        text-transform: uppercase;
    }

    .t-temp {
        font-size: 15px;
        font-weight: 800;
        color: #fff;
    }

    .t-desc {
        font-size: 12px;
        color: rgba(255,255,255,.55);
    }

    /* ── Responsive ── */
    @@media (max-width: 900px) {
        .weather-container {
            grid-template-columns: 1fr;
        }

        .temp-big {
            font-size: 5rem;
        }
    }
</style>

<div class="weather-wrapper">
    <div class="page-header text-center">
        <h1>ApiVerse</h1>
        <p>Geleceğin Hava Tahmin Deneyimi</p>
    </div>

    <div class="weather-container">

        <div>
            <div class="search-container">
                <h5>Lokasyon Belirle</h5>
                <form method="post">
                    <input type="text" name="cityname" class="custom-input form-control"
                           placeholder="Şehir ismini yazın..." required />
                    <button type="submit" class="btn custom-btn">
                        <i class="fa-solid fa-magnifying-glass me-2"></i> Verileri Getir
                    </button>
                </form>

                <div class="popular-cities">
                    <small>Popüler Şehirler</small>
                    <span class="city-badge">İstanbul</span>
                    <span class="city-badge">Tokyo</span>
                    <span class="city-badge">Paris</span>
                    <span class="city-badge">London</span>
                    <span class="city-badge">Berlin</span>
                    <span class="city-badge">Madrid</span>
                </div>
            </div>

            @if (Model?.list != null && Model.list.Length > 0)
            {
                var cur = Model.list[0];
                <div class="info-box mt-3">
                    <div class="ib-label">Ek Bilgiler</div>
                    <div class="ib-row"><span>Nem</span><span>%@cur.main.humidity</span></div>
                    <div class="ib-row"><span>Rüzgar</span><span>@cur.wind.speed km/h</span></div>
                    <div class="ib-row"><span>Hissedilen</span><span>@Math.Round(cur.main.temprature_feels_like)°</span></div>
                    <div class="ib-row"><span>Durum</span><span>@cur.weather[0].main</span></div>
                </div>
            }
        </div>

        <div id="weatherCard" class="weather-card bg-default">
            @if (Model?.list != null && Model.list.Length > 0)
            {
                var cur = Model.list[0];
                <i id="wIcon" class="fa-solid fa-cloud-sun wc-icon-float"></i>

                <div>
                    <div class="live-badge">&#9679;&nbsp; CANLI VERİ</div>
                    <div class="wc-city">@(ViewBag.SearchCity ?? Model.city?.name)</div>
                    <div class="wc-sub">@Model.city?.country — @DateTime.Now.ToString("dd MMMM, dddd")</div>
                </div>

                <div class="temp-row">
                    <div class="temp-big">@Math.Round(cur.main.temprature)°</div>
                    <div class="temp-meta">
                        <p>@cur.weather[0].description</p>
                        <span>Hissedilen @Math.Round(cur.main.temprature_feels_like)°</span>
                    </div>
                </div>

                <div>
                    <div class="pill-row">
                        <div class="pill-stat">
                            <span class="ps-label">Nem</span>
                            <span class="ps-val">%@cur.main.humidity</span>
                        </div>
                        <div class="pill-stat pill-sep">
                            <span class="ps-label">Rüzgar</span>
                            <span class="ps-val">@cur.wind.speed km/h</span>
                        </div>
                        <div class="pill-stat pill-sep">
                            <span class="ps-label">Hissedilen</span>
                            <span class="ps-val">@Math.Round(cur.main.temprature_feels_like)°</span>
                        </div>
                    </div>

                    <div class="ai-block">
                        <div class="ai-title"> ApiVerse AI Önerisi</div>
                        <div class="ai-body">@GetRecommendation(cur.weather[0].main)</div>
                        @if (!string.IsNullOrEmpty(Model.AIRecommendations))
                        {
                            <div class="ai-extra">
                                @Html.Raw(Model.AIRecommendations.Replace("\n", "<br/>"))
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-solid fa-wind"></i>
                    <h3>Keşfetmeye Hazır mısınız?</h3>
                    <p>Dünya üzerindeki herhangi bir şehrin hava durumunu<br>saniyeler içinde öğrenin.</p>
                </div>
            }
        </div>
    </div>
    <br />
    <br />
    <br />
    <div class="ticker-outer">
        <div class="ticker-label">
            <span class="dot"></span> CANLI
        </div>
        <div class="ticker-scroll">
            <div class="ticker-track" id="tickerTrack">
                <div class="t-item"><span class="t-desc">Veriler yükleniyor...</span></div>
            </div>
        </div>
    </div>
</div>


<script>
    /* ── Hava kartı rengi ── */
    window.addEventListener('DOMContentLoaded', function () {
        const main = "@(Model?.list != null && Model.list.Length > 0 ? Model.list[0].weather[0].main.ToLower() : "")";
        const card = document.getElementById('weatherCard');
        const icon = document.getElementById('wIcon');
        if (!card) return;

        if (main.includes("clear") || main.includes("sun")) {
            card.className = 'weather-card bg-sunny';
            if (icon) { icon.className = 'fa-solid fa-sun wc-icon-float'; }
        } else if (main.includes("cloud")) {
            card.className = 'weather-card bg-cloudy';
            if (icon) { icon.className = 'fa-solid fa-cloud wc-icon-float'; }
        } else if (main.includes("rain") || main.includes("drizzle")) {
            card.className = 'weather-card bg-rainy';
            if (icon) { icon.className = 'fa-solid fa-cloud-showers-heavy wc-icon-float'; }
        } else if (main.includes("snow")) {
            card.className = 'weather-card bg-snowy';
            if (icon) { icon.className = 'fa-solid fa-snowflake wc-icon-float'; }
        } else if (main.includes("thunder")) {
            card.className = 'weather-card bg-thunder';
            if (icon) { icon.className = 'fa-solid fa-bolt wc-icon-float'; }
        }
    });

    /* ── Ticker ── */
    (function () {
        const cities  = ['Istanbul', 'Berlin', 'Liverpool', 'Paris', 'Tokyo', 'Madrid', 'London'];
        const BASE    = 'https://localhost:7239/api/WeatherApi';
        let data      = [];
        let pos       = 0;

        function dotCls(main) {
            const m = (main || '').toLowerCase();
            if (m.includes('clear') || m.includes('sun')) return 'td-clear';
            if (m.includes('cloud'))                      return 'td-cloud';
            if (m.includes('rain') || m.includes('drizzle')) return 'td-rain';
            if (m.includes('snow'))                       return 'td-snow';
            if (m.includes('thunder'))                    return 'td-thunder';
            return 'td-def';
        }

        function buildTrack() {
            const track = document.getElementById('tickerTrack');
            const doubled = [...data, ...data];
            track.innerHTML = doubled.map(d =>
                `<div class="t-item">
                    <span class="t-dot ${dotCls(d.main)}"></span>
                    <span class="t-city">${d.city}</span>
                    <span class="t-temp">${Math.round(d.temp)}°C</span>
                    <span class="t-desc">${d.desc}</span>
                </div>`
            ).join('');
            animate();
        }

        function animate() {
            const track = document.getElementById('tickerTrack');
            let last = null;
            const items = track.querySelectorAll('.t-item');
            const half  = items.length > 0 ? items[0].offsetWidth * data.length : 200 * data.length;

            (function step(ts) {
                if (!last) last = ts;
                pos += (ts - last) * 0.042;
                last = ts;
                if (pos >= half) pos -= half;
                track.style.transform = `translateX(${-pos}px)`;
                requestAnimationFrame(step);
            })(performance.now());
        }

        async function fetchCity(city) {
            try {
                const res  = await fetch(`${BASE}/${encodeURIComponent(city)}`);
                if (!res.ok) return null;
                const json = await res.json();
                if (!json.list?.length) return null;
                const cur  = json.list[0];
                return {
                    city: json.city?.name || city,
                    temp: cur.main.temprature,
                    desc: cur.weather[0].description,
                    main: cur.weather[0].main
                };
            } catch { return null; }
        }

        async function loadAll() {
            const results = await Promise.all(cities.map(fetchCity));
            data = results.filter(Boolean);
            if (data.length) buildTrack();
        }

        loadAll();
        setInterval(loadAll, 5 * 60 * 1000);
    })();
</script>