@{
    ViewData["Title"] = "ApiVerse Rota Planlayıcı";
    Layout = "~/Views/ApiVerseLayout/Layout.cshtml";
}

<style>
    /* =========================
           ⚪️ CLEAN WHITE & FIXED UI
        ========================= */

    /* Satır yüksekliğini eşitleyen yapı */
    .equal-height {
        display: flex;
        align-items: stretch;
    }

    .planner-card {
        height: 100%;
        display: flex;
        flex-direction: column;
        min-height: 700px;
    }

    #map {
        height: 100% !important;
        min-height: 700px;
        width: 100%;
        border-radius: 20px;
        border: 1px solid #dee2e6;
    }

    /* Ulaşım Modları (Kategori) Düzenlemesi */
    .travel-modes {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
    }

    .mode-btn {
        flex: 1;
        background: #ffffff;
        border: 1px solid #dee2e6;
        color: #6c757d;
        padding: 10px 5px;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 600;
    }

        .mode-btn i {
            margin-right: 6px;
            font-size: 14px;
        }

        .mode-btn.active {
            background: #e7f1ff;
            border-color: #0d6efd;
            color: #0d6efd;
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.1);
        }

    /* AI Tavsiye Paneli */
    .ai-advice-container {
        background: #f0f7ff;
        border-left: 4px solid #0d6efd;
        border-radius: 12px;
        padding: 15px;
        margin-top: 20px;
        display: none;
    }

    .ai-title {
        color: #0d6efd;
        font-weight: 800;
        font-size: 11px;
        text-transform: uppercase;
    }

    .ai-content {
        color: #333;
        font-size: 13px;
        line-height: 1.6;
        margin-top: 8px;
    }

    /* Input & Form */
    .form-control {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #dee2e6 !important;
    }

    .btn-primary {
        background: #0d6efd;
        border: none;
        transition: 0.2s;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row g-4 equal-height">
        <div class="col-lg-4 d-flex">
            <div class="card white-card rounded-4 p-4 shadow-sm planner-card w-100 border-0">
                <div>
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary rounded-3 p-3 me-3 shadow-sm">
                            <i class="fas fa-location-arrow text-white"></i>
                        </div>
                        <div>
                            <h4 class="m-0 fw-bold">ApiVerse Rota</h4>
                            <small class="text-muted">Akıllı Yol Planlayıcı</small>
                        </div>
                    </div>

                    <label class="small fw-bold text-muted uppercase mb-2 d-block">ULAŞIM TÜRÜ</label>
                    <div class="travel-modes">
                        <button type="button" class="mode-btn active" data-mode="DRIVING"><i class="fas fa-car"></i> ARABA</button>
                        <button type="button" class="mode-btn" data-mode="WALKING"><i class="fas fa-walking"></i> YÜRÜYÜŞ</button>
                        <button type="button" class="mode-btn" data-mode="TRANSIT"><i class="fas fa-subway"></i> METRO</button>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-muted uppercase">BAŞLANGIÇ</label>
                        <input type="text" id="origin-input" class="form-control" placeholder="Nereden?">
                    </div>

                    <div class="mb-4">
                        <label class="small fw-bold text-muted uppercase">VARIŞ</label>
                        <input type="text" id="destination-input" class="form-control" placeholder="Nereye?">
                    </div>

                    <button id="calculate-btn" class="btn btn-primary w-100 py-3 fw-bold rounded-3">ROTAYI HESAPLA</button>
                </div>

                <div class="mt-auto">
                    <div id="result-panel" class="mt-4" style="display:none;">
                        <div class="p-3 rounded-3 bg-light border">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small text-muted">Mesafe:</span>
                                <span id="distance-text" class="fw-bold text-dark">0 km</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="small text-muted">Süre:</span>
                                <span id="duration-text" class="fw-bold text-primary">0 dk</span>
                            </div>
                        </div>
                    </div>

                    <div id="ai-advice-panel" class="ai-advice-container">
                        <div class="ai-title"><i class="fas fa-robot me-1"></i> ApiVerse AI Önerisi</div>
                        <div id="ai-advice-content" class="ai-content">
                            <div class="spinner-border spinner-border-sm text-primary"></div> Analiz ediliyor...
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8 d-flex">
            <div id="map"></div>
        </div>
    </div>
</div>

<script src="https://maps.googleapis.com/maps/api/js?key=x&libraries=places&language=tr&region=TR&callback=initMap" async defer></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    let map, directionsService, directionsRenderer;
    let selectedMode = 'DRIVING';

    function initMap() {
        map = new google.maps.Map(document.getElementById("map"), {
            zoom: 13,
            center: { lat: 41.0082, lng: 28.9784 },
            disableDefaultUI: false
        });

        directionsService = new google.maps.DirectionsService();
        directionsRenderer = new google.maps.DirectionsRenderer({
            map: map,
            polylineOptions: { strokeColor: "#0d6efd", strokeWeight: 6 }
        });

        const autocompleteOptions = { componentRestrictions: { country: "tr" } };
        new google.maps.places.Autocomplete(document.getElementById("origin-input"), autocompleteOptions);
        new google.maps.places.Autocomplete(document.getElementById("destination-input"), autocompleteOptions);
    }

    $('.mode-btn').click(function() {
        $('.mode-btn').removeClass('active');
        $(this).addClass('active');
        selectedMode = $(this).data('mode');
    });

    $('#calculate-btn').click(function() {
        const origin = $('#origin-input').val();
        const dest = $('#destination-input').val();

        if (origin && dest) {
            directionsService.route({
                origin: origin,
                destination: dest,
                travelMode: google.maps.TravelMode[selectedMode]
            }, (response, status) => {
                if (status === "OK") {
                    directionsRenderer.setDirections(response);
                    const route = response.routes[0].legs[0];

                    $('#result-panel').show();
                    $('#distance-text').text(route.distance.text);
                    $('#duration-text').text(route.duration.text);

                    // AI TAVSİYESİ
                    fetchAiAdvice(origin, dest, route.distance.text, route.duration.text, selectedMode);
                }
            });
        }
    });

    function fetchAiAdvice(origin, destination, distance, duration, mode) {
        $('#ai-advice-panel').fadeIn();
        $('#ai-advice-content').html('<div class="spinner-border spinner-border-sm text-primary"></div> Yapay zeka rotayı inceliyor...');

        $.post("/Location/GetAiTravelAdvice", {
            origin: origin, destination: destination, distance: distance, duration: duration, mode: mode
        }, function(data) {
            // Yıldızları (**) temizle ve satır sonlarını yap
            let cleanText = data.advice.replace(/\*\*/g, "");
            $('#ai-advice-content').html(cleanText.replace(/\n/g, "<br>"));

            // Harita senkronizasyonu
            setTimeout(() => { google.maps.event.trigger(map, 'resize'); }, 200);
        });
    }
</script>