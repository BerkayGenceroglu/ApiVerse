@model WeeklyFixturesViewModel
@{
    ViewData["Title"] = "Fixtures";
    Layout = "~/Views/ApiVerseLayout/Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Süper Lig Fikstür</h4>
        <p class="text-muted small mb-0">1 hafta önce · Bu hafta · Gelecek hafta</p>
    </div>
    <i class="fa-solid fa-futbol fa-2x text-muted"></i>
</div>

<ul class="nav nav-pills mb-4" id="fixtureTab">
    <li class="nav-item">
        <a class="nav-link" href="#lastweek" data-bs-toggle="tab">Geçen Hafta</a>
    </li>
    <li class="nav-item">
        <a class="nav-link active" href="#thisweek" data-bs-toggle="tab">Bu Hafta</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#nextweek" data-bs-toggle="tab">Gelecek Hafta</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="/Football/Predictions">Yapay Zeka Maç Tahminleri</a>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade" id="lastweek">
        @await Html.PartialAsync("_MatchList", Model.LastWeek)
    </div>
    <div class="tab-pane fade show active" id="thisweek">
        @await Html.PartialAsync("_MatchList", Model.ThisWeek)
    </div>
    <div class="tab-pane fade" id="nextweek">
        @await Html.PartialAsync("_MatchList", Model.NextWeek)
    </div>


</div>